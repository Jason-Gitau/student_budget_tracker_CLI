{
  "name": "student-budget-tracker",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "description": "Simple TypeScript CLI app for tracking a student's monthly budget.",
  "main": "dist/index.js",
  "scripts": {
    "start": "ts-node src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run --dir test --pool=threads --no-file-parallelism --maxWorkers=1 --exclude dist/** --exclude dist-test/**",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.0"
  }
}
